{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "intervention_capture_ui.py"
    }
  ],
  "functions": {
    "app/**/*.py": {
      "runtime": "python3.10"
    }
  }
}
